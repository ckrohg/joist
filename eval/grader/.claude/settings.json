            "command": "curl -s -X POST http://localhost:4379/api/hooks -H 'Content-Type: application/json' -d \"{\\\"event\\\":\\\"PreCompact\\\"}\" --connect-timeout 2 2>/dev/null; exit 0",
            "async": true
          }
