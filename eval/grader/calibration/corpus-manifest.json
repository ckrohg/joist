  "_purpose": "Sequestered, archetype-diverse human-corpus scaffold for calibrating the UPLEVELED grader (grade-element-crops.mjs axis-delta tolerances + region-judge rollup). This is the DENOMINATOR the path-to-1:1 protocol calibrates against: every entry names a (source_url, clone_page) pair, an archetype (blog|marketing|saas), a DEV|HOLDOUT split, and a human_ledger that is EITHER a real recorded human audit (slotted from the labels we already own) OR null (pending a fresh, out-of-sample human audit — NEVER fabricated).",
  "_generated_by": "corpus-scaffold subagent (uplevel-grader fusion verdict)",
  "_generated_at_utc": "2026-06-15",
  "_principle": "The grader is calibrated/tuned ONLY on the DEV split. The HOLDOUT split is sequestered: its human_ledger MUST stay null until a human scores it BLIND (no grader number shown first), so HOLDOUT is a true out-of-sample generalization test and cannot leak into tolerance tuning. Do NOT auto-fill HOLDOUT human scores from grader output — that would collapse the holdout into a self-fulfilling fit.",

  "archetypes": {
    "blog": "long editorial/article pages (single-column prose, inline code, footnotes, markdown-derived). Stress: text fidelity, inline-link styling, code chips, emoji/dividers — the FINE defects the full-page thumbnail cannot resolve.",
    "marketing": "landing/docs/product pages with a hero, logo strip, primary CTA, feature panels. Stress: logo fidelity, hero richness, CTA chrome, imagery panels — the human-salient fatal classes.",
    "saas": "app/dashboard/pricing/auth pages with dense componentry (forms, tables, cards, nav rails). Stress: layout density, responsive reflow, component chrome."
  },

  "human_ledger_schema": {
    "_doc": "Per-pair human audit. null until a human scores the pair. When recorded, this shape:",
    "overall_0_100": "integer 0-100. 0 = totally wrong/broken/worthless clone; 100 = indistinguishable from source. This is the SCALAR calibration anchor (regress grader composite against it).",
    "per_defect": {
      "_doc": "Array of the human-salient defect CLASSES the human ticked, each with a severity. Classes align 1:1 with the grader's axis-delta `class` field + region-judge FATAL_OF buckets so a human tick can be matched to a fired axis.",
      "shape": "[{ defect_class: 'wrong-logo'|'missing-logo'|'invisible-heading'|'invisible-text'|'blank-hero'|'unstyled-cta'|'missing-imagery'|'missing-section'|'overlapping-sections'|'wrong-layout'|'color-off'|'font-off'|'image-missing', severity: 'fatal'|'high'|'med'|'low', note?: string }]"
    },
    "scored_by": "human initials/email (provenance).",
    "scored_at_utc": "ISO date.",
    "blind": "boolean — true if the human scored WITHOUT seeing any grader number first (required for HOLDOUT; preserves out-of-sample integrity).",
    "source_label_file": "provenance: which existing label file this ledger was slotted from (human-results.json | midrange-human-results.json), or 'fresh-audit' for a new score.",
    "source_label_id": "the pair_id in that file (P01..P18 | M01..M04), where applicable."
  },

